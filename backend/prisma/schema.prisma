datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Tournament {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("setup") // setup, active, finished
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories Category[]
  judges     Judge[]
}

model Category {
  id             String      @id @default(cuid())
  name           String
  tournamentId   String
  groupSize      Int         @default(4)
  pasadasCount   Int         @default(2)    // number of runs per group
  qualifyCount   Int         @default(5)    // exact count of participants to qualify
  tournament     Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  
  participants   Participant[]
  rounds         Round[]
}

model Judge {
  id           String     @id @default(cuid())
  name         String
  pin          String     @unique
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  
  scores     Score[]
}

model Participant {
  id         String     @id @default(cuid())
  name       String
  alias      String?
  categoryId String
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  groupPlacements GroupParticipant[]
  scores          Score[]
}

model Round {
  id         String   @id @default(cuid())
  number     Int      // 1 = qualifiers, 2 = semi, 3 = final etc
  status     String   @default("pending") // pending, active, completed
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  groups     Group[]
  scores     Score[]
}

model Group {
  id            String   @id @default(cuid())
  name          String   // e.g. "Heat 1"
  status        String   @default("pending") // pending, active, completed
  currentPasada Int      @default(0) // 0 = not started, 1 = pasada 1, etc.
  roundId       String
  round         Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  
  participants GroupParticipant[]
}

model GroupParticipant {
  id            String      @id @default(cuid())
  order         Int         // skating order 1, 2, 3...
  groupId       String
  participantId String
  group         Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([groupId, participantId])
}

model Score {
  id            String      @id @default(cuid())
  value         Int         // 1 to 5
  pasadaNumber  Int         @default(1) // which run this score belongs to
  judgeId       String
  participantId String
  roundId       String
  
  judge       Judge       @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  round       Round       @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([judgeId, participantId, roundId, pasadaNumber])
}

model SystemState {
  id                   String  @id @default("global") // Single row
  status               String  @default("setup")
  // setup | torneo_iniciado | grupo_activo | pasada_activa | pasada_cerrada
  // | grupo_cerrado | ranking_visible | ronda_cerrada | clasificacion | torneo_finalizado
  activeTournamentId   String?
  activeCategoryId     String?
  activeRoundId        String?
  activeGroupId        String?
  activeParticipantId  String?
  activePasadaNumber   Int     @default(1)
  
  // Consensus tracking (stored as JSON array of judgeIds who confirmed)
  consensusEndPasada   String  @default("[]") // JSON array of judgeIds
  consensusNextPasada  String  @default("[]")
  consensusNextGroup   String  @default("[]")
  
  updatedAt            DateTime @updatedAt
}
